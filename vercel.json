    {
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
        "source": "/",
        "destination": "/index.html"
        },
        {
        "source": "/details",
        "destination": "/details.html"
        },
        {
        "source": "/login",
        "destination": "/login.html"
        },
        {
        "source": "/dashboard",
        "destination": "/dashboard.html"
        }
    ]
    }